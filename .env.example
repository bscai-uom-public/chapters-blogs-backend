# Local MongoDB example:
# BLOG_MONGODB_URL=mongodb://localhost:27017
# Atlas example:
# BLOG_MONGODB_URL=mongodb+srv://<db_user>:<db_password>@<cluster-host>/<db_name>?retryWrites=true&w=majority&appName=<app-name>
BLOG_MONGODB_URL=mongodb://localhost:27017
BLOG_MONGODB_DB_NAME=blog_db

# Supabase project URL (no trailing slash)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Allowed frontend origins (JSON array string)
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://your-frontend-domain.com"]

# Optional runtime metadata
ENVIRONMENT=development
SERVICE_VERSION=1.0.0
DEBUG=false
DEBUG_ENDPOINTS_ENABLED=true
