BLOG_MONGODB_URL=mongodb://localhost:27017
BLOG_MONGODB_DB_NAME=blog_db

# Supabase project URL (no trailing slash)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Comma-separated frontend origins allowed to call backend
BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Optional runtime metadata
ENVIRONMENT=production
SERVICE_VERSION=1.0.0
DEBUG=false
DEBUG_ENDPOINTS_ENABLED=false
